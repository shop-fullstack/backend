    "eslint-plugin-prettier": "^5.2.1",
    "jest": "^30.3.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
